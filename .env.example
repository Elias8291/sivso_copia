APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- MySQL: DB_* define la única base (usuarios Laravel + tablas SIVSO). La conexión «copiasivso» usa los mismos valores.
#
# SIVSO_DATA_CONNECTION=copiasivso
#
# db:seed ejecuta SuperUser + datos copiasivso si existen archivos:
#   database/seeders/csv/copiasivso/*.csv + _manifest.json
#   database/seeders/xlsx/copiasivso/*.xlsx + _manifest.json
# Solo superusuario (p. ej. CI): SIVSO_SKIP_DATA_SEED=true
#
# Tras seed / migración: exportar empleados a CSV (storage/app/exports/):
# SIVSO_EXPORT_EMPLEADOS_CSV=true
# Ruta fija opcional: SIVSO_EXPORT_EMPLEADOS_CSV_PATH=storage/app/exports/empleados.csv
# Solo export: php artisan db:seed --class=ExportEmpleadosCsvSeeder
#
# Tras import CSV: reconciliar delegacion_id con tabla legacy «delegacion» (automático en db:seed si hay manifest CSV).
# Regenerar database/seeders/csv/copiasivso/empleados.csv desde la BD:
#   php artisan db:seed --class=SyncEmpleadosCsvToSnapshotSeeder
# O en db:seed completo: SIVSO_SYNC_EMPLEADOS_CSV_SNAPSHOT=true
#
# Migración legacy a otra base vacía (php artisan sivso:migrate-copiasivso-legacy --force):
#   DB_DATABASE=base_nueva   → esquema normalizado + Laravel
#   SIVSO_LEGACY_SOURCE_DATABASE=copiasivso   → solo lectura: concentrado, propuesta, dependences, delegacion, delegado
# Credenciales del origen: SIVSO_LEGACY_SOURCE_HOST, _PORT, _USERNAME, _PASSWORD (por defecto = DB_*)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
